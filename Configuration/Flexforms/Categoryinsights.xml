<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <sheetTitle> General </sheetTitle>
                <type>array</type>
                <el>
                    <settings.storePid>
                        <label>LLL:EXT:insights/Resources/Private/Language/locallang.xlf:storePid</label>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>1</size>
                            <required>1</required>
                            <maxitems>1</maxitems>
                            <minitems>1</minitems>
                        </config>
                    </settings.storePid>
                    <settings.detailPid>
                        <label>LLL:EXT:insights/Resources/Private/Language/locallang.xlf:detailPid</label>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <required>1</required>
                            <size>1</size>
                            <maxitems>1</maxitems>
                            <minitems>1</minitems>
                        </config>
                    </settings.detailPid>
                    <settings.categories>
                        <label>Select Categories</label>
                        <config>
                            <type>select</type>
                            <renderType>selectTree</renderType>
                            <foreign_table>sys_category</foreign_table>
                            <foreign_table_where>AND sys_category.sys_language_uid IN (-1, 0) ORDER
                                BY sys_category.title ASC</foreign_table_where>
                            <treeConfig>
                                <parentField>parent</parentField>
                                <appearance>
                                    <expandAll>true</expandAll>
                                    <showHeader>true</showHeader>
                                </appearance>
                            </treeConfig>
                            <size>10</size>
                            <minitems>0</minitems>
                            <maxitems>99</maxitems>
                        </config>
                    </settings.categories>
                    <settings.orderBy>
                        <label>LLL:EXT:insights/Resources/Private/Language/locallang.xlf:orderBy</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:created</label>
                                    <value>crdate</value>
                                </numIndex>
                                <numIndex index="1">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:modify</label>
                                    <value>tstamp</value>
                                </numIndex>
                                <numIndex index="2">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:post_title</label>
                                    <value>title</value>
                                </numIndex>
                                <numIndex index="3">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:post_publishdate</label>
                                    <value>publishdate</value>
                                </numIndex>
                                <numIndex index="4">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:post_archivedate</label>
                                    <value>archivedate</value>
                                </numIndex>
                            </items>
                        </config>
                    </settings.orderBy>

                    <settings.orderDir>
                        <label>LLL:EXT:insights/Resources/Private/Language/locallang.xlf:orderDir</label>
                        <config>
                            <type>select</type>
                            <required>1</required>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:desc</label>
                                    <value>desc</value>
                                </numIndex>
                                <numIndex index="1">
                                    <label>
                                        LLL:EXT:insights/Resources/Private/Language/locallang.xlf:asc</label>
                                    <value>asc</value>
                                </numIndex>
                            </items>
                        </config>
                    </settings.orderDir>
                    <settings.pageSize>
                        <label>LLL:EXT:insights/Resources/Private/Language/locallang.xlf:pageSize</label>
                        <config>
                            <type>number</type>
                            <required>1</required>
                        </config>
                    </settings.pageSize>
                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>
 