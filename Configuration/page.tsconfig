                CType = insights_postlist 
            }
        } 
        insights_recommended {
            iconIdentifier = insights
            title = LLL:EXT:insights/Resources/Private/Language/locallang.xlf:recommended_title
            description = LLL:EXT:insights/Resources/Private/Language/locallang.xlf:recommended_desc
