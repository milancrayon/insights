mod.wizards.newContentElement.wizardItems.insights { 
    header = LLL:EXT:insights/Resources/Private/Language/locallang.xlf:insights_tab_title
    after = common
    elements { 
        insights_postlist {
            iconIdentifier = insights
            title = LLL:EXT:insights/Resources/Private/Language/locallang.xlf:postlist_title
            description = LLL:EXT:insights/Resources/Private/Language/locallang.xlf:postlist_desc
